Package: dafrjulia
Title: R Interface to the Julia 'DataAxesFormats' Package
Version: 0.1.0
Authors@R: c(
    person("Aviezer", "Lifshitz", , "aviezer.lifshitz@weizmann.ac.il", role = c("aut", "cre"),
           comment = c(ORCID = "0000-0002-8458-9507")),
